#!/usr/bin/env sh
# Portal MU — Pre-commit hook (v.108.31)
# Block commit untuk file sensitive

# Files yang DILARANG commit
BLOCKED_PATTERNS="^(.*\.env(\..*)?$|.*\.keystore$|.*\.jks$|.*\.key$|.*\.pem$|service-account.*\.json$|google-services\.json$|GoogleService-Info\.plist$|firebase-adminsdk-.*\.json$|secrets/.*|\.secrets/.*)"

# Cek staged files
STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Loop cek setiap staged file
BLOCKED=""
for FILE in $STAGED_FILES; do
    if echo "$FILE" | grep -qE "$BLOCKED_PATTERNS"; then
        BLOCKED="$BLOCKED\n  - $FILE"
    fi
done

if [ -n "$BLOCKED" ]; then
    echo ""
    echo "========================================"
    echo "  COMMIT DIBLOKIR — File sensitive"
    echo "========================================"
    echo ""
    echo "File berikut tidak boleh di-commit:"
    printf "$BLOCKED\n"
    echo ""
    echo "Cara unstage file:"
    echo "  git reset HEAD <file>"
    echo ""
    echo "Kalau yakin perlu commit (jangan untuk credentials!):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

# Lanjut pakai lint-staged untuk format
npx lint-staged
