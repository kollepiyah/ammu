{
  "name": "portal-mambaul-ulum",
  "version": "98.0626",
  "private": true,
  "description": "Portal Mambaul Ulum - legacy HTML5 + Vue 3 widgets + Capacitor wrap",
  "scripts": {
    "build:widgets": "cd vue-widgets && npm run build",
    "build:css": "tailwindcss -i ./src/tailwind-input.css -o ./public/dist/tailwind.css --minify",
    "build:css:watch": "tailwindcss -i ./src/tailwind-input.css -o ./public/dist/tailwind.css --watch",
    "build:html": "html-minifier-terser --collapse-whitespace --remove-comments --minify-css true --minify-js true --output public/index.min.html public/index.html",
    "build:all": "npm run build:widgets && npm run build:css && npm run build:html",
    "lint": "eslint . --fix --ext .js,.vue,.html",
    "format": "prettier --write \"**/*.{js,vue,html,css,json}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "lh:ci": "lhci autorun",
    "lh:check": "lhci autorun --collect.staticDistDir=public",
    "firebase:emulator": "firebase emulators:start",
    "firebase:deploy": "node scripts/deploy-minified.cjs",
    "firebase:deploy:raw": "firebase deploy --only hosting",
    "firebase:deploy:legacy": "firebase deploy --only hosting",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
    "build:aab": "node scripts/build-aab.cjs",
    "build:apk": "node scripts/build-apk.cjs",
    "deploy:full": "npm run firebase:deploy && npm run build:aab",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,vue,html,css,json}": "prettier --write"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@lhci/cli": "^0.14.0",
    "@vue/eslint-config-prettier": "^10.1.0",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.0",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "html-minifier-terser": "^7.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.2.10",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "vitest": "^2.1.8",
    "workbox-cli": "^7.3.0"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/push-notifications": "^6.0.4",
    "@capacitor/share": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@capacitor/filesystem": "^6.0.1"
  }
}
