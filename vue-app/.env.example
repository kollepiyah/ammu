# Vue 3 SPA environment variables (Vite)
# Copy ke .env.local untuk dipakai (.env.local di-gitignore)

# Optional: 1 = pakai Firebase emulator suite lokal
VITE_USE_FIREBASE_EMULATOR=0

# App Check — site key reCAPTCHA v3 (web/PWA). Kosong = App Check OFF di web.
VITE_APPCHECK_RECAPTCHA_KEY=

# App Check NATIVE (Capacitor/Electron) — debug token, didaftarkan di Firebase Console:
#   App Check > app Android "Ammu Online" > kebab menu > Manage debug tokens > Add.
#   Hanya diterapkan saat native (web tetap pakai reCAPTCHA). Untuk fase INTERNAL TESTING.
#   Produksi nanti: ganti ke Play Integrity (plugin @capacitor-firebase/app-check + firebase JS v12).
VITE_APPCHECK_DEBUG_TOKEN=
